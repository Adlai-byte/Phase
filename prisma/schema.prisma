generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  password      String
  name          String
  phone         String?
  role          String          @default("OWNER") // SUPERADMIN, OWNER
  verified      Boolean         @default(false)
  avatarUrl     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  boardingHouses BoardingHouse[]
  subscription  Subscription?
  notifications Notification[]
  auditLogs     AuditLog[]
  announcementsCreated Announcement[] @relation("AnnouncementCreator")
  announcementReads AnnouncementRead[]
  supportTickets SupportTicket[]

  @@index([role, verified])
}

model BoardingHouse {
  id              String    @id @default(cuid())
  name            String
  address         String
  city            String    @default("Mati City")
  description     String?
  type            String    @default("MIXED") // ALL_FEMALE, ALL_MALE, MIXED
  latitude        Float?
  longitude       Float?
  coverImage      String?
  verified        Boolean   @default(false)
  published       Boolean   @default(false)
  flagged         Boolean   @default(false)
  flagReason      String?
  hasCurfew       Boolean   @default(false)
  curfewTime      String?
  restrictions    String?
  amenities       String?
  contactPhone    String?
  contactEmail    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms           Room[]
  tenants         Tenant[]
  invoices        Invoice[]
  bills           Bill[]
  deposits        Deposit[]
  contracts       Contract[]
  reminderConfigs ReminderConfig[]

  @@index([ownerId])
  @@index([city, type, published])
}

model Room {
  id                  String   @id @default(cuid())
  number              String
  floor               Int      @default(1)
  capacity            Int      @default(1)
  monthlyRate         Float
  roomType            String   @default("BEDSPACER") // BEDSPACER, SOLO_ROOM, DUAL_BED, APARTMENT, STUDIO, FAMILY_ROOM
  electricityIncluded Boolean  @default(false)
  hasAircon           Boolean  @default(false)
  hasWifi             Boolean  @default(false)
  hasBathroom         Boolean  @default(false)
  amenities           String?
  status              String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  boardingHouseId     String
  boardingHouse       BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  tenants             Tenant[]
  transfers           RoomTransfer[]
  targetTransfers     RoomTransfer[] @relation("TargetRoom")

  @@unique([boardingHouseId, number])
  @@index([boardingHouseId, status])
}

model Tenant {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String
  emergencyContact String?
  emergencyPhone  String?
  tag             String?   // STUDENT, WORKING_PROFESSIONAL, OTHER
  photoUrl        String?
  moveInDate      DateTime
  moveOutDate     DateTime?
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE, PENDING
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roomId          String?
  room            Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  bills           Bill[]
  transfers       RoomTransfer[]
  deposits        Deposit[]
  contracts       Contract[]

  @@index([boardingHouseId, status])
  @@index([roomId])
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  amount          Float
  dueDate         DateTime
  paidDate        DateTime?
  status          String   @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  type            String   @default("RENT") // RENT, ELECTRICITY, WATER, OTHER
  description     String?
  sentVia         String?
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)

  reminderLogs    ReminderLog[]

  @@index([boardingHouseId, status])
  @@index([tenantId])
  @@index([dueDate])
}

model Bill {
  id              String   @id @default(cuid())
  type            String
  amount          Float
  period          String
  currentReading  Float?
  previousReading Float?
  ratePerUnit     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)

  @@index([boardingHouseId, period])
  @@index([tenantId])
}

model RoomTransfer {
  id           String   @id @default(cuid())
  reason       String?
  status       String   @default("PENDING") // PENDING, APPROVED, COMPLETED, CANCELLED
  transferDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromRoomId   String
  fromRoom     Room     @relation(fields: [fromRoomId], references: [id], onDelete: Cascade)
  toRoomId     String
  toRoom       Room     @relation("TargetRoom", fields: [toRoomId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fromRoomId])
  @@index([toRoomId])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // VERIFY_OWNER, REJECT_OWNER, PAY_INVOICE, CREATE_TENANT, TRANSFER_ROOM, FLAG_LISTING, UNPUBLISH, LOGIN, etc.
  entityType String?  // User, BoardingHouse, Invoice, Tenant, Room, etc.
  entityId   String?
  details    String?  // JSON string with extra context
  ipAddress  String?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String   @default("INFO") // INFO, WARNING, MAINTENANCE, UPDATE
  targetPlan String?  // null=all, STARTER, PROFESSIONAL, ENTERPRISE
  targetUserId String? // null=all owners, specific owner id
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  createdById String
  createdBy  User     @relation("AnnouncementCreator", fields: [createdById], references: [id])
  reads      AnnouncementRead[]

  @@index([createdAt])
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  readAt         DateTime @default(now())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
}

model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  message     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  response    String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Deposit {
  id              String    @id @default(cuid())
  amount          Float
  datePaid        DateTime
  refundStatus    String    @default("HELD") // HELD, PARTIALLY_REFUNDED, FULLY_REFUNDED, FORFEITED
  refundAmount    Float?
  refundDate      DateTime?
  refundReason    String?
  conditions      String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([boardingHouseId])
}

model Contract {
  id              String    @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  monthlyRate     Float
  depositAmount   Float?
  terms           String?
  status          String    @default("DRAFT") // DRAFT, ACTIVE, EXPIRED, TERMINATED
  signedDate      DateTime?
  signedByTenant  Boolean   @default(false)
  signedByOwner   Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([boardingHouseId, status])
}

model ReminderConfig {
  id              String   @id @default(cuid())
  name            String
  triggerType     String   // BEFORE_DUE, AFTER_DUE
  triggerDays     Int
  channel         String   // EMAIL, SMS, BOTH
  templateSubject String?
  templateBody    String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  boardingHouseId String
  boardingHouse   BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  logs            ReminderLog[]

  @@index([boardingHouseId])
}

model ReminderLog {
  id               String   @id @default(cuid())
  status           String   // SENT, FAILED, SKIPPED
  channel          String
  errorMessage     String?
  sentAt           DateTime @default(now())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reminderConfigId String
  reminderConfig   ReminderConfig @relation(fields: [reminderConfigId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([reminderConfigId])
}

model RateLimit {
  id       String   @id @default(cuid())
  key      String   @unique
  count    Int      @default(0)
  resetAt  DateTime

  @@index([key])
}

model Subscription {
  id          String   @id @default(cuid())
  plan        String   @default("STARTER")
  maxRooms    Int      @default(10)
  maxTenants  Int      @default(15)
  emailSms    Boolean  @default(false)
  analytics   Boolean  @default(false)
  amount      Float    @default(0)
  status      String   @default("ACTIVE")
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
